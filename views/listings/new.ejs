<% layout("/layouts/bolierplate") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Create a new Post</h3>

    <form method="POST" 
          action="/listing" 
          enctype="multipart/form-data"
          novalidate 
          class="needs-validation">

      <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text"
               name="listing[title]"
               class="form-control"
               placeholder="Add a catchy title"
               required>
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="listing[description]"
                  class="form-control"
                  required></textarea>
      </div>

      <!-- ✅ FIXED IMAGE FIELD -->
      <div class="mb-3">
        <label class="form-label">Upload Image</label>
        <input type="file"
               name="listing[image]"
               class="form-control">
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label class="form-label">Price</label>
          <input name="listing[price]"
                 class="form-control"
                 required>
        </div>

        <div class="mb-3 col-md-8">
          <label class="form-label">Country</label>
          <input type="text"
                 name="listing[country]"
                 class="form-control"
                 required>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Location</label>
        <input type="text"
               name="listing[location]"
               class="form-control"
               required>
      </div>

      <button class="btn btn-dark add-btn mt-3 mb-3">
        Add
      </button>

    </form>
  </div>
</div>